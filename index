<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BOSSA — Madrid</title>
  <meta name="description" content="BOSSA es un concepto de música electrónica en Madrid. Minimal, deep tech y tech house. Eventos mensuales con identidad propia." />
  <meta property="og:title" content="BOSSA — Madrid" />
  <meta property="og:description" content="Minimal. Deep Tech. Tech House. Madrid." />
  <meta property="og:url" content="https://bossatheclub.com" />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red: #dc143c;
      --black: #080808;
      --white: #f0ece4;
      --gray: #1a1a1a;
      --gray-mid: #2e2e2e;
    }

    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
      cursor: none;
    }

    /* CURSOR */
    .cursor {
      width: 8px;
      height: 8px;
      background: var(--red);
      border-radius: 50%;
      position: fixed;
      top: 0; left: 0;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s ease, width 0.2s ease, height 0.2s ease, background 0.2s ease;
    }
    .cursor.hover {
      width: 28px;
      height: 28px;
      background: transparent;
      border: 1px solid var(--red);
    }

    /* GRAIN OVERLAY */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.035;
      pointer-events: none;
      z-index: 9998;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 28px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      mix-blend-mode: normal;
    }

    nav::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(8,8,8,0.9) 0%, transparent 100%);
      z-index: -1;
    }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
      letter-spacing: 0.3em;
      color: var(--white);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 40px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
      opacity: 0.6;
      transition: opacity 0.2s;
    }

    .nav-links a:hover {
      opacity: 1;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 48px 72px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(220,20,60,0.08) 0%, transparent 70%),
                  radial-gradient(ellipse 40% 40% at 20% 80%, rgba(220,20,60,0.04) 0%, transparent 60%);
    }

    .hero-line {
      position: absolute;
      top: 0; bottom: 0;
      left: 48px;
      width: 1px;
      background: linear-gradient(to bottom, transparent 0%, var(--red) 30%, var(--red) 70%, transparent 100%);
      opacity: 0.15;
    }

    .hero-logo-wrap {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: min(520px, 70vw);
      opacity: 0;
      animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    }

    .hero-logo-wrap svg path {
      fill: var(--white);
    }

    .hero-bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      opacity: 0;
      animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
    }

    .hero-tagline {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-style: italic;
      font-size: clamp(13px, 1.5vw, 16px);
      letter-spacing: 0.12em;
      opacity: 0.5;
      line-height: 1.8;
    }

    .hero-tagline strong {
      font-style: normal;
      font-weight: 400;
      opacity: 1;
      color: var(--red);
    }

    .hero-scroll {
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.3;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    .hero-scroll::after {
      content: '';
      width: 1px;
      height: 48px;
      background: var(--white);
      display: block;
      animation: scrollPulse 2s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; transform: scaleY(1); }
      50% { opacity: 0.7; transform: scaleY(1.1); }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* SECTIONS */
    section {
      padding: 120px 48px;
    }

    .section-label {
      font-size: 10px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 48px;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .section-label::before {
      content: '';
      width: 32px;
      height: 1px;
      background: var(--red);
    }

    /* CONCEPTO */
    #concepto {
      border-top: 1px solid var(--gray-mid);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }

    .concepto-text h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(52px, 7vw, 96px);
      line-height: 0.92;
      letter-spacing: 0.02em;
      margin-bottom: 40px;
    }

    .concepto-text h2 em {
      font-style: normal;
      color: var(--red);
      -webkit-text-stroke: 0px;
    }

    .concepto-text p {
      font-size: 15px;
      line-height: 1.85;
      opacity: 0.65;
      max-width: 480px;
    }

    .concepto-text p + p {
      margin-top: 20px;
    }

    .concepto-right {
      padding-top: 20px;
    }

    .sound-tags {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .sound-tag {
      padding: 20px 0;
      border-bottom: 1px solid var(--gray-mid);
      font-family: 'Bebas Neue', sans-serif;
      font-size: 32px;
      letter-spacing: 0.08em;
      display: flex;
      justify-content: space-between;
      align-items: center;
      opacity: 0.3;
      transition: opacity 0.3s;
    }

    .sound-tag:hover {
      opacity: 1;
    }

    .sound-tag span {
      font-family: 'Barlow', sans-serif;
      font-size: 10px;
      font-weight: 300;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--red);
    }

    /* PRÓXIMOS EVENTOS */
    #eventos {
      border-top: 1px solid var(--gray-mid);
      background: var(--gray);
    }

    .eventos-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 64px;
    }

    .eventos-header h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(40px, 5vw, 72px);
      line-height: 1;
      letter-spacing: 0.03em;
    }

    .eventos-header a {
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--red);
      text-decoration: none;
      border-bottom: 1px solid rgba(220,20,60,0.3);
      padding-bottom: 2px;
      transition: border-color 0.2s;
    }

    .eventos-header a:hover {
      border-color: var(--red);
    }

    .eventos-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .evento-item {
      display: grid;
      grid-template-columns: 100px 1fr auto;
      gap: 40px;
      align-items: center;
      padding: 32px 0;
      border-bottom: 1px solid var(--gray-mid);
      text-decoration: none;
      color: inherit;
      transition: background 0.2s;
      position: relative;
      overflow: hidden;
    }

    .evento-item::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 2px;
      background: var(--red);
      transform: scaleY(0);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      transform-origin: bottom;
    }

    .evento-item:hover::before {
      transform: scaleY(1);
    }

    .evento-fecha {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 42px;
      line-height: 1;
      opacity: 0.3;
      letter-spacing: 0.02em;
    }

    .evento-fecha small {
      display: block;
      font-family: 'Barlow', sans-serif;
      font-size: 10px;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.7;
      margin-top: 4px;
    }

    .evento-info h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    .evento-info p {
      font-size: 12px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.4;
    }

    .evento-cta {
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--red);
      opacity: 0;
      transition: opacity 0.2s;
    }

    .evento-item:hover .evento-cta {
      opacity: 1;
    }

    .no-eventos {
      padding: 64px 0;
      text-align: center;
      opacity: 0.3;
      font-size: 13px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    /* CONTACTO */
    #contacto {
      border-top: 1px solid var(--gray-mid);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }

    #contacto h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(48px, 6vw, 88px);
      line-height: 0.9;
      letter-spacing: 0.02em;
    }

    .contact-right {
      padding-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .contact-item {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .contact-item label {
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.4;
    }

    .contact-item a {
      font-size: 16px;
      color: var(--white);
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-item a:hover {
      color: var(--red);
    }

    .social-links {
      display: flex;
      gap: 24px;
      margin-top: 16px;
    }

    .social-link {
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
      opacity: 0.5;
      transition: opacity 0.2s, color 0.2s;
      padding: 12px 20px;
      border: 1px solid var(--gray-mid);
    }

    .social-link:hover {
      opacity: 1;
      color: var(--red);
      border-color: var(--red);
    }

    /* FOOTER */
    footer {
      padding: 32px 48px;
      border-top: 1px solid var(--gray-mid);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.25;
    }

    /* SCROLL REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* MOBILE */
    @media (max-width: 768px) {
      nav { padding: 24px 24px; }
      .nav-links { display: none; }
      .hero { padding: 0 24px 56px; }
      .hero-line { left: 24px; }
      section { padding: 80px 24px; }
      #concepto { grid-template-columns: 1fr; gap: 48px; }
      #contacto { grid-template-columns: 1fr; gap: 48px; }
      .eventos-header { flex-direction: column; align-items: flex-start; gap: 16px; }
      .evento-item { grid-template-columns: 72px 1fr; }
      .evento-cta { display: none; }
      footer { flex-direction: column; gap: 12px; text-align: center; padding: 24px; }
    }
  </style>
</head>
